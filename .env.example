# ════════════════════════════════════════════════════
#  KRESTON ESTATES — Environment Variables
# ════════════════════════════════════════════════════
#
#  HOW TO USE:
#  1. Copy this file and rename it to:  .env
#  2. Fill in your Hostinger email password below
#  3. Save the file and restart the server
#
# ════════════════════════════════════════════════════

# Your Hostinger email password for info@krestonestates.com
# (The same password you use to log into your email)
SMTP_PASS=your_email_password_here

# These are already set correctly for Hostinger — don't change them
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=info@krestonestates.com
